[Host]
# --- VPS 内网服务：强制走阿里 DNS，防止家里 RouterOS 把 xllx.site 误解析到内网 ---
bt.xllx.site = server:223.5.5.5
dns.xllx.site = server:223.5.5.5
panel.xllx.site = server:223.5.5.5
bw.xllx.site = server:223.5.5.5
nz.xllx.site = server:223.5.5.5
rss.xllx.site = server:223.5.5.5
an.xllx.site = server:223.5.5.5
ql.xllx.site = server:223.5.5.5
sub.xllx.site = server:223.5.5.5
sh.xllx.site = server:223.5.5.5
mail.xllx.site = server:223.5.5.5
blog.xllx.site = server:192.168.1.2
# --- 家庭服务：跟随系统 DNS ---
# 在家：系统 DNS = RouterOS → 解析到 192.168.1.2 → 直连内网
# 出门：系统 DNS = 运营商 → 解析到 VPS 公网 IP → 走 VPS 反代
*.xllx.site = server:system
*.018432.xyz = server:system

