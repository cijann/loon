Apple = select,DIRECT,US,HK,TW,JP,KR,SG,FINAL,url = http://cp.cloudflare.com/generate_204,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Apple_2.png
# --- 从 Surge 同步的策略组 ---
Disney+ = select,US,HK,TW,JP,KR,SG,url = http://cp.cloudflare.com/generate_204,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Disney.png
HBO = select,US,JP,HK,TW,KR,SG,url = http://cp.cloudflare.com/generate_204,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/HBO.png
Spotify = select,DIRECT,US,HK,TW,JP,KR,SG,url = http://cp.cloudflare.com/generate_204,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Spotify.png
Twitter = select,US,HK,TW,JP,KR,SG,url = http://cp.cloudflare.com/generate_204,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Twitter.png
Line = select,DIRECT,US,HK,TW,JP,KR,SG,url = http://cp.cloudflare.com/generate_204,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Line.png
Speedtest = select,DIRECT,US,HK,TW,JP,KR,SG,FINAL,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Speedtest.png
PayPal = select,US,HK,TW,JP,KR,SG,FINAL,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/PayPal.png
TestFlight = select,DIRECT,US,HK,TW,JP,KR,SG,FINAL,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/TestFlight.png
GlobalMedia = select,US,HK,TW,JP,KR,SG,FINAL,DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/GlobalMedia.png
Global = select,Auto,DIRECT,US,HK,TW,JP,KR,SG,FINAL,img-url = globe.badge.chevron.backward
Mainland = select,DIRECT,FINAL
Advertising = select,REJECT,DIRECT

# 场景策略
# [Proxy Group] 场景策略（已注释，暂不启用SSID自动切换）
# 香港手动场景 = ssid,default=香港手动策略,cellular=香港手动策略,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 日本手动场景 = ssid,default=日本手动策略,cellular=日本手动策略,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 韩国手动场景 = ssid,default=韩国手动策略,cellular=韩国手动策略,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 新国手动场景 = ssid,default=新国手动策略,cellular=新国手动策略,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 美国手动场景 = ssid,default=美国手动策略,cellular=美国手动策略,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 游戏手动场景 = ssid,default=游戏手动策略,cellular=游戏手动策略,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 全球手动场景 = ssid,default=Manual,cellular=Manual,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 香港自动场景 = ssid,default=HK,cellular=HK,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 台湾自动场景 = ssid,default=TW,cellular=TW,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 日本自动场景 = ssid,default=JP,cellular=JP,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 韩国自动场景 = ssid,default=KR,cellular=KR,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 新国自动场景 = ssid,default=SG,cellular=SG,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# 美国自动场景 = ssid,default=US,cellular=US,"null"=DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SSID.png
# --------------------------------
# 地区策略
Auto = url-test,全球节点,interval = 60,tolerance = 50,img-url = globe.badge.chevron.backward
HK = url-test,香港节点,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/HK.png
TW = url-test,台湾节点,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/TW.png
JP = url-test,日本节点,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/JP.png
KR = url-test,韩国节点,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/KR.png
SG = url-test,新国节点,interval = 60,tolerance = 50,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/SG.png
US = url-test,美国节点,interval = 60,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/US.png
# --------------------------------
# 兜底策略后备
Selection = select,DIRECT
FINAL = select,Auto,DIRECT,Selection,US,JP,HK,TW,KR,SG,img-url = https://raw.githubusercontent.com/Semporia/Hand-Painted-icon/master/Universal/Final.png

